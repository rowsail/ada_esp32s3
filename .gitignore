# ---- Build artifacts ----
**/build/
**/.objs/
**/.ada_build/
**/obj/
**/obj-*/
*.o
*.ali
sdkconfig
sdkconfig.old
managed_components/
dependencies.lock
# packaged images + linker maps + the bare-boot intermediate dir (regenerated by ./x build)
/examples/*/app.bin
/examples/*/app.elf
/examples/*/app.map
/examples/*/.noidf/
/examples/*/config/
/examples/*/.custom_build/
/examples/common/bare/bootloader/boot.elf
/examples/common/bare/bootloader/boot.map
/examples/common/bare/bootloader/bootloader.bin
**/__pycache__/

# ---- Generated native runtime (regenerate via hwtest/native/main/build_ada.sh) ----
/hwtest/native/rts/

# ---- Downloaded ACATS suite (large; not redistributed in this repo) ----
/ACATS42/

# ---- Regenerated ACATS filter work dir ----
/ACATS/work/

# ---- ACATS on-target runner scratch (regenerated by build_acats_runner.sh) ----
/ACATS/target/_build/
/ACATS/target/_probe/
/ACATS/target/_sweep/
**/.acats_build/

# ---- Per-example VS Code cruft (the ESP-IDF extension drops its own config here);
#      the project's real VS Code config is the repo-root .vscode/ ----
examples/*/.vscode/
b~*
