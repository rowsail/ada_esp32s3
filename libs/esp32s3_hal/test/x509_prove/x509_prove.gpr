--  Native project for SPARK-proving the pure X509 DER parser (untrusted-input
--  bounds safety).  No main: gnatprove analyses the SPARK_Mode => On units.
project X509_Prove is
   for Source_Dirs use ("../../src");
   for Object_Dir use "obj";
   for Source_Files use ("x509.ads", "x509.adb", "x509-der.ads", "x509-der.adb");
   package Compiler is
      for Default_Switches ("Ada") use ("-gnata", "-gnat2022");
   end Compiler;
end X509_Prove;
