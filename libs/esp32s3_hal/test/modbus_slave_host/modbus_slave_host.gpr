--  Native host test for Modbus.Slave's socket-free Process.  Modbus.Slave compiles
--  against the native runtime's real GNAT.Sockets (Run is present but unused here);
--  Process needs no sockets, so the framing/dispatch/exception path is checked
--  deterministically.  See run.sh.
project Modbus_Slave_Host is
   for Source_Dirs use (".", "../../src");
   for Object_Dir use "obj";
   for Exec_Dir use ".";
   for Main use ("modbus_slave_host.adb");
   for Source_Files use
     ("modbus_slave_host.adb",
      "modbus.ads",        "modbus.adb",
      "modbus-slave.ads",  "modbus-slave.adb");
   package Compiler is
      for Default_Switches ("Ada") use ("-g", "-O0", "-gnata", "-gnat2022");
   end Compiler;
end Modbus_Slave_Host;
