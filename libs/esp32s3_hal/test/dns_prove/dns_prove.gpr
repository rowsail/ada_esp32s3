--  Native project for SPARK-proving the pure DNS message layer: the response
--  parser (DNS_Client.Parse.Find_A_Record -- no run-time errors on any
--  malformed or malicious reply, name-compression pointers included) and the
--  query builder every transport shares (DNS_Client.Wire).  Only the parent
--  DNS_Client spec is needed to typecheck the children (GNAT.Sockets comes
--  from the native runtime); no sockets are analysed.  No main.
project Dns_Prove is
   for Source_Dirs use ("../../src");
   for Object_Dir use "obj";
   for Source_Files use
     ("dns_client.ads",
      "dns_client-parse.ads",
      "dns_client-parse.adb",
      "dns_client-wire.ads",
      "dns_client-wire.adb",
      "esp32s3.ads",
      "esp32s3-endian.ads",
      "esp32s3-endian.adb");
   package Compiler is
      for Default_Switches ("Ada") use ("-gnata", "-gnat2022");
   end Compiler;
end Dns_Prove;
