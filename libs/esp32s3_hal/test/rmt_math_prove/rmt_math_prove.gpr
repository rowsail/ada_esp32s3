--  Native project for SPARK-proving the pure RMT tick-divider math
--  (ESP32S3.RMT.Math.Divider).  The register-writing driver body stays unmarked
--  (SPARK off).  The parent specs are host-portable, so this compiles natively.
--  No main.
project RMT_Math_Prove is
   for Source_Dirs use ("../../src");
   for Object_Dir use "obj";
   for Source_Files use
     ("esp32s3.ads",
      "esp32s3-gpio.ads",
      "esp32s3-rmt.ads",
      "esp32s3-rmt-math.ads",
      "esp32s3-rmt-math.adb");
   package Compiler is
      for Default_Switches ("Ada") use ("-gnata", "-gnat2022");
   end Compiler;
end RMT_Math_Prove;
