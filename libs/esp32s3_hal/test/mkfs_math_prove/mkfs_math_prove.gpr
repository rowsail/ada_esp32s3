--  Native project for SPARK-proving the pure single-group ext4 layout math
--  (ESP32S3.Ext4.Mkfs.Math): the inode count / inode-table size / block
--  positions are bounded and internally consistent for any accepted device
--  size.  The register / block-device I/O in the Mkfs body stays unmarked
--  (SPARK off).  The parent specs are host-portable, so this compiles natively.
--  No main.
project Mkfs_Math_Prove is
   for Source_Dirs use ("../../src", "../../src/ext4");
   for Object_Dir use "obj";
   for Source_Files use
     ("esp32s3.ads",
      "esp32s3-block_dev.ads",
      "esp32s3-ext4.ads",
      "esp32s3-ext4-mkfs.ads",
      "esp32s3-ext4-mkfs-math.ads",
      "esp32s3-ext4-mkfs-math.adb");
   package Compiler is
      for Default_Switches ("Ada") use ("-gnata", "-gnat2022");
   end Compiler;
end Mkfs_Math_Prove;
