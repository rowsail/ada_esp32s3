--  Native project for SPARK-proving the pure little-endian byte-pair -> signed
--  16-bit combine of the QMI8658C IMU driver (Signed -- raw axis counts).  The
--  I2C register I/O (Read_Regs / Read_Axes / Configure / ...) is hardware and
--  stays unmarked (SPARK_Mode off).  The I2C and GPIO specs are host-portable
--  (no register layer), so this compiles natively.  No main.
project QMI8658C_Prove is
   for Source_Dirs use ("../../src");
   for Object_Dir use "obj";
   for Source_Files use
     ("esp32s3.ads",
      "esp32s3-gpio.ads",
      "esp32s3-i2c.ads",
      "esp32s3-qmi8658c.ads",
      "esp32s3-qmi8658c.adb");
   package Compiler is
      for Default_Switches ("Ada") use ("-gnata", "-gnat2022");
   end Compiler;
end QMI8658C_Prove;
