--  Native project for SPARK-proving the pure DAC volume register-value math of
--  the ES8311 codec driver (Vol_Reg -- 0..100 % -> reg 0x32 value).  The I2C /
--  I2S register I/O (Setup / Write_Reg / Play / ...) is hardware and stays
--  unmarked (SPARK_Mode off).  The I2C, I2S, GDMA and GPIO specs are
--  host-portable (no register layer), so this compiles natively.  No main.
project ES8311_Prove is
   for Source_Dirs use ("../../src");
   for Object_Dir use "obj";
   for Source_Files use
     ("esp32s3.ads",
      "esp32s3-gpio.ads",
      "esp32s3-gdma.ads",
      "esp32s3-i2c.ads",
      "esp32s3-i2s.ads",
      "esp32s3-es8311.ads",
      "esp32s3-es8311.adb");
   package Compiler is
      for Default_Switches ("Ada") use ("-gnata", "-gnat2022");
   end Compiler;
end ES8311_Prove;
