--  Native (x86) harness for DNS_Client's UDP and TCP transports: written
--  against the GNAT.Sockets SUBSET the bare-metal facade provides, so the
--  same sources compile here against the native runtime's real GNAT.Sockets
--  and run against the local Python mini-server.  See run.sh.
project DNS_Host is
   for Source_Dirs use (".", "../../src");
   for Object_Dir use "obj";
   for Exec_Dir use ".";
   for Main use ("dns_host.adb");
   for Source_Files use
     ("dns_host.adb",
      "dns_client.ads",
      "dns_client.adb",
      "dns_client-parse.ads",
      "dns_client-parse.adb",
      "dns_client-wire.ads",
      "dns_client-wire.adb",
      "esp32s3.ads",
      "esp32s3-endian.ads",
      "esp32s3-endian.adb",
      "esp32s3-strings.ads",
      "esp32s3-strings.adb");
   package Compiler is
      for Default_Switches ("Ada") use ("-g", "-O0", "-gnata", "-gnat2022");
   end Compiler;
end DNS_Host;
