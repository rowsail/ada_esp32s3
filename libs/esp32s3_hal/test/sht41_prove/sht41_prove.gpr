--  Native project for SPARK-proving the pure computational helpers of the SHT41
--  temperature/humidity driver: the CRC-8 checksum (CRC8 / CRC_Good) and the
--  integer datasheet conversions (Ticks / To_Temp_MC / To_Hum_MRH).  The I2C
--  bus exchange (Transact / Measure / Setup / ...) is hardware and stays
--  unmarked (SPARK_Mode off).  The I2C and GPIO specs are host-portable (no
--  register layer in the spec), so this compiles natively.  No main.
project SHT41_Prove is
   for Source_Dirs use ("../../src");
   for Object_Dir use "obj";
   for Source_Files use
     ("esp32s3.ads",
      "esp32s3-gpio.ads",
      "esp32s3-i2c.ads",
      "esp32s3-sht41.ads",
      "esp32s3-sht41.adb");
   package Compiler is
      for Default_Switches ("Ada") use ("-gnata", "-gnat2022");
   end Compiler;
end SHT41_Prove;
