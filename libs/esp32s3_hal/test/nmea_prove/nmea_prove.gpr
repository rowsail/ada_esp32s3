--  Native project for SPARK-proving the pure NMEA-0183 sentence decoder
--  (ESP32S3.GPS.NMEA.Parse and helpers) -- no run-time errors on any
--  attacker/garbage GPS sentence string.  Only specs of the hardware parent
--  units are needed to typecheck; no bodies, no registers.  No main.
project Nmea_Prove is
   for Source_Dirs use ("../../src");
   for Object_Dir use "obj";
   for Source_Files use
     ("esp32s3.ads",
      "esp32s3-gpio.ads",
      "esp32s3-uart.ads",
      "esp32s3-gps.ads",
      "esp32s3-gps-nmea.ads",
      "esp32s3-gps-nmea.adb");
   package Compiler is
      for Default_Switches ("Ada") use ("-gnata", "-gnat2022");
   end Compiler;
end Nmea_Prove;
