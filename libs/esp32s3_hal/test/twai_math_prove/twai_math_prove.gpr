--  Native project for SPARK-proving the pure CAN bit-timing prescaler math of
--  the TWAI driver (ESP32S3.TWAI.Math.Prescaler).  The register-writing Engine
--  body stays unmarked (SPARK off).  The parent specs are host-portable (no
--  register layer), so this compiles natively.  No main.
project TWAI_Math_Prove is
   for Source_Dirs use ("../../src");
   for Object_Dir use "obj";
   for Source_Files use
     ("esp32s3.ads",
      "esp32s3-gpio.ads",
      "esp32s3-twai.ads",
      "esp32s3-twai-math.ads",
      "esp32s3-twai-math.adb");
   package Compiler is
      for Default_Switches ("Ada") use ("-gnata", "-gnat2022");
   end Compiler;
end TWAI_Math_Prove;
